{
  "manifest_version": 3,
  "name": "GradeItRight Sync",
  "version": "1.0.0",
  "description": "Sync your Infinite Campus grades to GradeItRight in one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.infinitecampus.com/*",
    "https://*.infinitecampus.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GradeItRight Sync"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.infinitecampus.com/*",
        "https://*.infinitecampus.org/*"
      ],
      "js": ["content-script-ic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["auth.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
